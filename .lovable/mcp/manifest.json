{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://arqzquiibhfddjhcpxxk.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "finbot-mcp",
      "version": "0.1.0",
      "title": "FinBot"
    },
    "tools": [
      {
        "name": "list_transactions",
        "title": "List transactions",
        "description": "List the signed-in user's financial transactions (income, expense, investment), most recent first. Optionally filter by type, category, or date range (YYYY-MM-DD).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "type": {
              "description": "Filter by transaction type.",
              "type": "string",
              "enum": [
                "income",
                "expense",
                "investment"
              ]
            },
            "category": {
              "description": "Filter by category slug (e.g. alimentacao, salario).",
              "type": "string"
            },
            "from": {
              "description": "Start date inclusive, YYYY-MM-DD.",
              "type": "string"
            },
            "to": {
              "description": "End date inclusive, YYYY-MM-DD.",
              "type": "string"
            },
            "limit": {
              "description": "Max rows to return (default 50).",
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "add_transaction",
        "title": "Add transaction",
        "description": "Add an income, expense, or investment transaction for the signed-in user. Amount is positive; type distinguishes direction. For investments, provide investment_type and investment_operation.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "income",
                "expense",
                "investment"
              ],
              "description": "Transaction type."
            },
            "amount": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Positive numeric amount in BRL."
            },
            "category": {
              "type": "string",
              "minLength": 1,
              "description": "Category slug (e.g. alimentacao, transporte, salario, freelance, outros_despesa, outros_receita)."
            },
            "description": {
              "description": "Free-text description.",
              "type": "string"
            },
            "transaction_date": {
              "type": "string",
              "description": "Date YYYY-MM-DD."
            },
            "institution": {
              "description": "Institution / broker (investments).",
              "type": "string"
            },
            "investment_type": {
              "description": "Required when type=investment.",
              "type": "string",
              "enum": [
                "cdb",
                "tesouro_direto",
                "acoes",
                "fii",
                "criptomoedas",
                "previdencia",
                "poupanca",
                "etf",
                "renda_fixa",
                "outros"
              ]
            },
            "investment_operation": {
              "description": "Required when type=investment.",
              "type": "string",
              "enum": [
                "deposit",
                "withdraw",
                "yield",
                "loss"
              ]
            }
          },
          "required": [
            "type",
            "amount",
            "category",
            "transaction_date"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "delete_transaction",
        "title": "Delete transaction",
        "description": "Delete one of the signed-in user's transactions by id.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "Transaction id to delete."
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "get_financial_summary",
        "title": "Get financial summary",
        "description": "Aggregate the signed-in user's income, expenses, investments and net balance across an optional date range.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "from": {
              "description": "Start date inclusive, YYYY-MM-DD.",
              "type": "string"
            },
            "to": {
              "description": "End date inclusive, YYYY-MM-DD.",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
